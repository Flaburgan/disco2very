{
  "name": "disco2very",
  "version": "0.6.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite",
    "format": "prettier --write '**/*.{ts,tsx,css,scss,json,yml}'",
    "lint": "eslint --max-warnings=0 --cache '**/*.{ts,tsx}'",
    "lint-fix": "eslint --fix --cache '**/*.{ts,tsx}'",
    "preview": "vite preview",
    "test-e2e": "playwright test",
    "update-ademe": "node scripts/update-ademe-data.mjs",
    "i18n-extract": "lingui extract",
    "i18n-compile": "lingui compile --typescript"
  },
  "dependencies": {
    "@lingui/core": "^5.8.0",
    "@lingui/react": "^5.8.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lingui/babel-plugin-lingui-macro": "^5.8.0",
    "@lingui/cli": "^5.8.0",
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^10.6.0",
    "eslint-plugin-lingui": "^0.14.0",
    "http-server": "^14.1.1",
    "prettier": "^3.9.4",
    "sass": "^1.32.10",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.16.0",
    "vite": "^8.1.3"
  }
}
